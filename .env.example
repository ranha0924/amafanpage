# AMR Fanpage Environment Variables

# 환경 설정
NODE_ENV=development
# production으로 설정 시 HSTS 헤더 자동 활성화

# HSTS 강제 활성화 (NODE_ENV와 별개로 설정 가능)
ENABLE_HSTS=false

# 서버 포트
PORT=3000

# 관리자 API 키 (정산 API 인증용)
# 프로덕션에서는 반드시 복잡한 키를 사용하세요!
ADMIN_KEY=your_secret_admin_key_here

# 허용된 CORS 도메인 (콤마로 구분)
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Discord Webhook URL (신고 알림용, 선택사항)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Firebase 서비스 계정 (정산 API용)
# Firebase Console > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성
#
# 🔒 보안 권장: 개별 환경변수 사용 (JSON 블롭보다 안전)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# private_key는 따옴표로 감싸고 \n을 그대로 유지
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ⚠️ 또는 기존 방식: JSON 전체를 한 줄로 (비권장)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}
